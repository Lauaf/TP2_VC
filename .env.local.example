APP_NAME=Dog Breed Recognition TP2
# Modelo de embeddings
# Opciones: baseline | resnet18_finetuned | cnn_custom
EMBEDDING_MODEL=baseline
MODEL_PATH=../models
RESNET18_MODEL_NAME=resnet18_finetuned.pth
CNN_CUSTOM_MODEL_NAME=cnn_custom.pth

# Similitud
SIMILARITY_METRIC=cosine
SIMILARITY_THRESHOLD=0.55
# Top K
TOP_K=10
IMAGE_SIZE=224
# Debe coincidir con el embedding del modelo elegido
EMBEDDING_DIM=512

# YOLO
YOLO_MODEL=yolov8n.pt
YOLO_CONF_THRESHOLD=0.25
# Clase "dog" en COCO
YOLO_DOG_CLASS_ID=16

# Paths (relativos a src/)
EMBEDDINGS_PATH=../data/embeddings.json
DATA_PATH=../data
DATASET_PATH=../data/dataset
OUTPUT_PATH=../output
# CORS permitido
CORS_ORIGINS="http://localhost:8080"
MAX_WORKERS=2

# PostgreSQL / pgvector
# Poner en true si queres usar postgres + pgvector
USE_PGVECTOR=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dogs
POSTGRES_USER=dogs_user
POSTGRES_PASSWORD=dogs_pass
